# Options: auto, ollama, openai
AURA_PROVIDER=auto

# Local AI through Ollama. Install Ollama, then run: ollama pull llama3.1:8b
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Optional OpenAI fallback. Leave blank if you want local-only mode.
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-5.5
